# Environment
.env
.env.local
.env.*.local

# Infra runtime secrets — template (.env.tst.example) is committed; the real file is not
infra/.env.tst

# Dependencies
node_modules/

# Next.js
.next/

# PocketBase data
pb_data/

# Auto-generated PB collection-creation migrations (per-environment IDs).
# Hand-written migrations (named e.g. YYYYMMDD_*.js or *_add_*.js) are tracked.
pb_migrations/*_created_*.js

# Build
dist/
out/
*.tsbuildinfo

# next-pwa / serwist generated service worker artifacts
public/sw.js
public/swe-worker-*.js
public/workbox-*.js

# Stray local artifacts
ssh-keygen

# Test artifacts
playwright-report/
test-results/

# PWA service worker artifacts (generated by next-pwa)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
public/swe-worker-*.js.map

# Stray local outputs
/ssh-keygen

# Local scratch — design specs, diagnostic scripts, audit notes (never commit)
tmp/

# Claude Code scheduled-task lock — runtime state, not source
.claude/scheduled_tasks.lock

# Personal AI dev framework — lives off-repo per ADR-013.
# Agent charters, path-scoped rules, and skill bundles are personal workflow,
# not project artifact. Source of truth is ~/.claude/ (per-user); engram holds
# the compact runtime projections.
.claude/agents/
.claude/rules/
.claude/skills/
