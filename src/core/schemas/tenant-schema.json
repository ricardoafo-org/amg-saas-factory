{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LocalBusiness",
  "description": "Single source of truth for any tenant skin in the AMG SaaS Factory",
  "type": "object",
  "required": ["tenantId", "businessName", "industry", "address", "contact", "branding", "services", "operatingHours", "privacyPolicy", "ivaRate", "locale", "currency"],
  "properties": {
    "tenantId":     { "type": "string", "minLength": 2 },
    "businessName": { "type": "string", "minLength": 2 },
    "industry":     { "type": "string" },
    "tagline":      { "type": "string" },
    "address": {
      "type": "object",
      "required": ["street", "city", "postalCode", "region", "country", "geo"],
      "properties": {
        "street":     { "type": "string" },
        "city":       { "type": "string" },
        "postalCode": { "type": "string" },
        "region":     { "type": "string" },
        "country":    { "type": "string" },
        "geo": {
          "type": "object",
          "required": ["lat", "lng"],
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      }
    },
    "contact": {
      "type": "object",
      "required": ["phone", "email"],
      "properties": {
        "phone":         { "type": "string" },
        "email":         { "type": "string", "format": "email" },
        "whatsapp":      { "type": "string" },
        "googleMapsUrl": { "type": "string", "format": "uri" }
      }
    },
    "branding": {
      "type": "object",
      "required": ["primaryColor", "secondaryColor", "fontFamily"],
      "properties": {
        "primaryColor":   { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor":    { "type": "string" },
        "fontFamily":     { "type": "string" },
        "logoUrl":        { "type": "string" }
      }
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "basePrice", "duration"],
        "properties": {
          "id":          { "type": "string" },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "basePrice":   { "type": "number", "minimum": 0 },
          "duration":    { "type": "number", "minimum": 1 },
          "category":    { "type": "string" }
        }
      }
    },
    "operatingHours": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["day", "open", "close"],
        "properties": {
          "day":    { "type": "string", "enum": ["monday","tuesday","wednesday","thursday","friday","saturday","sunday"] },
          "open":   { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
          "close":  { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" },
          "closed": { "type": "boolean" }
        }
      }
    },
    "privacyPolicy": {
      "type": "object",
      "required": ["url", "version", "hash"],
      "properties": {
        "url":     { "type": "string", "format": "uri" },
        "version": { "type": "string" },
        "hash":    { "type": "string", "minLength": 64, "maxLength": 64 }
      }
    },
    "ivaRate":   { "type": "number", "minimum": 0, "maximum": 1 },
    "locale":    { "type": "string" },
    "currency":  { "type": "string" }
  }
}
