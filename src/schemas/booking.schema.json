{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Booking",
  "type": "object",
  "required": ["tenant_id", "customer_name", "customer_email", "service_type", "scheduled_at", "status", "base_amount", "iva_rate"],
  "properties": {
    "id":              { "type": "string" },
    "tenant_id":       { "type": "string" },
    "customer_name":   { "type": "string", "minLength": 2, "maxLength": 100 },
    "customer_email":  { "type": "string", "format": "email" },
    "customer_phone":  { "type": "string" },
    "service_type":    { "type": "string" },
    "scheduled_at":    { "type": "string", "format": "date-time" },
    "notes":           { "type": "string" },
    "status":          { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
    "base_amount":     { "type": "number", "minimum": 0 },
    "iva_rate":        { "type": "number", "minimum": 0, "maximum": 1 },
    "created":         { "type": "string", "format": "date-time" },
    "updated":         { "type": "string", "format": "date-time" }
  }
}
