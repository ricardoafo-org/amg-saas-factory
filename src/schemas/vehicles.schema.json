{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vehicle",
  "description": "Customer vehicle record. Linked to customers via customer_id (text, not PB relation, kept loosely-coupled). itv_expiry powers ITV reminder flows.",
  "x-pb-collection": {
    "type": "base",
    "name": "vehicles"
  },
  "type": "object",
  "required": ["tenant_id", "plate"],
  "properties": {
    "id": { "type": "string" },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 50 },
    "customer_id": { "type": "string", "maxLength": 50 },
    "plate": { "type": "string", "minLength": 1, "maxLength": 20 },
    "brand": { "type": "string", "maxLength": 50 },
    "model": { "type": "string", "maxLength": 50 },
    "year": { "type": "number", "minimum": 1900, "maximum": 2100 },
    "fuel_type": {
      "type": "string",
      "enum": ["gasolina", "diesel", "electrico", "hibrido"]
    },
    "engine_cc": { "type": "number", "minimum": 0 },
    "last_km": { "type": "number", "minimum": 0 },
    "itv_expiry": { "type": "string", "format": "date" },
    "notes": { "type": "string", "maxLength": 2000 },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  },
  "x-pb-indexes": [
    "CREATE INDEX idx_vehicles_tenant_customer ON vehicles (tenant_id, customer_id)",
    "CREATE UNIQUE INDEX idx_vehicles_tenant_plate ON vehicles (tenant_id, plate)",
    "CREATE INDEX idx_vehicles_tenant_itv ON vehicles (tenant_id, itv_expiry)"
  ],
  "x-pb-rules": {
    "listRule": "tenant_id = @request.auth.tenant_id",
    "viewRule": "tenant_id = @request.auth.tenant_id",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  }
}
