{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConsentLog",
  "type": "object",
  "required": ["tenant_id", "subject_email", "policy_version", "policy_hash", "consented", "consented_at", "form_context"],
  "properties": {
    "id":             { "type": "string" },
    "tenant_id":      { "type": "string" },
    "subject_email":  { "type": "string", "format": "email" },
    "policy_version": { "type": "string" },
    "policy_hash":    { "type": "string", "minLength": 64, "maxLength": 64 },
    "consented":      { "type": "boolean" },
    "consented_at":   { "type": "string", "format": "date-time" },
    "ip_address":     { "type": "string" },
    "user_agent":     { "type": "string" },
    "form_context":   { "type": "string" },
    "created":        { "type": "string", "format": "date-time" },
    "updated":        { "type": "string", "format": "date-time" }
  }
}
