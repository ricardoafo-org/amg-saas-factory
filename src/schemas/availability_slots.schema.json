{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AvailabilitySlot",
  "description": "Bookable time slot. Capacity tracks how many concurrent bookings the slot allows; booked tracks current count. The 2026-04-26 SEV-1 was caused by this collection having no schema (only id) on tst PB. This file is the test that catches that class of failure (rubric F5).",
  "x-pb-collection": {
    "type": "base",
    "name": "availability_slots"
  },
  "type": "object",
  "required": [
    "tenant_id",
    "slot_date",
    "start_time",
    "end_time",
    "is_available"
  ],
  "properties": {
    "id": { "type": "string" },
    "tenant_id": { "type": "string", "minLength": 1, "maxLength": 50 },
    "service_id": { "type": "string", "maxLength": 50 },
    "slot_date": { "type": "string", "format": "date" },
    "start_time": {
      "type": "string",
      "pattern": "^[0-2][0-9]:[0-5][0-9]$",
      "description": "Local 24h HH:MM"
    },
    "end_time": {
      "type": "string",
      "pattern": "^[0-2][0-9]:[0-5][0-9]$",
      "description": "Local 24h HH:MM"
    },
    "capacity": { "type": "number", "minimum": 1 },
    "booked": { "type": "number", "minimum": 0 },
    "is_available": { "type": "boolean" },
    "created": { "type": "string", "format": "date-time" },
    "updated": { "type": "string", "format": "date-time" }
  },
  "x-pb-indexes": [
    "CREATE INDEX idx_avs_tenant_date ON availability_slots (tenant_id, slot_date)",
    "CREATE UNIQUE INDEX idx_avs_tenant_date_start ON availability_slots (tenant_id, slot_date, start_time)"
  ],
  "x-pb-rules": {
    "listRule": "tenant_id = @request.auth.tenant_id || @request.auth.id = ''",
    "viewRule": "tenant_id = @request.auth.tenant_id || @request.auth.id = ''",
    "createRule": null,
    "updateRule": null,
    "deleteRule": null
  }
}
