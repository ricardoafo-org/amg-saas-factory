# Inner tst Caddy. HTTP-only (port 80). TLS is terminated upstream by the
# edge router (Caddyfile.edge), which reverse-proxies here over the shared
# `amg_edge` docker network using the `tst-caddy` alias.
#
# When tst becomes self-fronting again (e.g. dedicated VPS), revert this to
# `{$TST_DOMAIN} {` and re-add `ports: 80/443` in docker-compose.tst.yml.

{
    auto_https off
    servers {
        # Trust X-Forwarded-* from private-range peers (the edge container).
        trusted_proxies static private_ranges
    }
}

:80 {
    encode zstd gzip

    # PocketBase admin UI is NOT publicly reachable.
    # Must come BEFORE handle_path /pb/* — handle blocks are mutually exclusive
    # in Caddy v2: first match wins. Inline @matchers + respond at top level lose
    # the ordering battle to handle_path because handle_path expands to a route block.
    handle /pb/_* {
        respond 404
    }

    # Proxy /pb/* to PocketBase (for client-side API calls only)
    handle_path /pb/* {
        reverse_proxy pocketbase:8090
    }

    # Everything else to Next.js
    handle {
        reverse_proxy app:3000 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Real-IP {remote_host}
        }
    }

    # Access logging — method + path + status only, no bodies, no headers
    log {
        output stdout
        format console
        level INFO
    }
}
