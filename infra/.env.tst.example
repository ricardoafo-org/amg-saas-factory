# Copy this file to `.env.tst` on the VPS. Replace every placeholder.
# NEVER commit the populated `.env.tst` -- it contains real secrets.

# ---------------------------------------------------------------------------
# Domain (Caddy uses this for automatic HTTPS via Let's Encrypt)
# Replace with your actual domain once DNS is configured.
# ---------------------------------------------------------------------------
TST_DOMAIN=tst.example.com

# ---------------------------------------------------------------------------
# Docker image tag (set by the deploy script; override here only for manual runs)
# ---------------------------------------------------------------------------
IMAGE_TAG=tst

# ---------------------------------------------------------------------------
# Application runtime secrets (loaded by the app container via env_file)
# ---------------------------------------------------------------------------
POCKETBASE_URL=http://pocketbase:8090
NEXT_PUBLIC_BASE_URL=https://tst.example.com
TENANT_ID=your-tenant-id-here

# Resend (transactional email)
RESEND_API_KEY=your-resend-api-key-here

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_FROM_NUMBER=+34000000000

# Anthropic (AI/chatbot)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
