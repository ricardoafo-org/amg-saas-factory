# =============================================================================
# AMG SaaS Factory — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# All secrets are loaded server-side only (no NEXT_PUBLIC_ prefix for secrets).
# =============================================================================


# -----------------------------------------------------------------------------
# PocketBase (database + auth)
# -----------------------------------------------------------------------------

# URL where PocketBase is running.
# Local dev: http://127.0.0.1:8090
# Docker / production: http://pocketbase:8090 (internal) or https://pb.yourdomain.com
POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase superadmin credentials — used by migration scripts and schemas:sync only.
# NOT used at runtime by the Next.js app.
PB_SUPERADMIN_EMAIL=admin@example.com
PB_SUPERADMIN_PASSWORD=change-me-in-production


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Public URL of the Next.js app — used for absolute URLs in emails and OG meta.
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Tenant identifier — must match the tenantId in clients/*/config.json.
TENANT_ID=talleres-amg

# Next.js environment. Set to "production" in production builds.
NODE_ENV=development


# -----------------------------------------------------------------------------
# AI — Anthropic Claude (NLP fallback)
# -----------------------------------------------------------------------------

# Used by src/actions/nlp.ts as a fallback when the local NLP classifier has
# low confidence on free-text user input in the chatbot.
# Model: claude-haiku-4-5 (fast, cheap). System prompt is prompt-cached.
# Optional — if blank, the chatbot falls back to the local classifier only.
# Get key from console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Email — Resend (https://resend.com)
# -----------------------------------------------------------------------------

# Resend API key. Get from resend.com/api-keys.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address used for all outbound emails. Must be a verified domain in Resend.
RESEND_FROM_EMAIL=noreply@yourdomain.com


# -----------------------------------------------------------------------------
# SMS — Twilio (https://twilio.com/console)
# -----------------------------------------------------------------------------

# Account SID — found on the Twilio Console dashboard.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Token — found on the Twilio Console dashboard. Keep secret.
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio phone number to send SMS from (E.164 format).
# Must be a verified Twilio number or Messaging Service SID.
TWILIO_FROM_NUMBER=+34XXXXXXXXX


# -----------------------------------------------------------------------------
# Observability — Sentry (Sprint 5)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking. Get from sentry.io/settings/projects.
# Leave blank to disable Sentry in development.
SENTRY_DSN=

# Sentry org and project slugs — needed for source map uploads in CI.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------------------
# Analytics — Plausible (Sprint 5)
# -----------------------------------------------------------------------------

# Your Plausible domain (e.g. yourdomain.com). Used in the script tag.
# Cookieless — no consent needed, but disclosed in /politica-de-cookies.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=


# -----------------------------------------------------------------------------
# CI / Docker (set in GitHub Actions Secrets or Docker Compose environment)
# -----------------------------------------------------------------------------

# Port Next.js listens on inside the Docker container.
# Default: 3000. Only set this if you need a non-standard port.
# PORT=3000

# -------------------------------------------------------------------
# Developer tooling — machine identities for local Claude Code
# -------------------------------------------------------------------
# Fine-grained PAT for the GitHub bot account (e.g. amg-bot) used by
# Claude to commit and open PRs on behalf of automation.
# Scopes required: Contents RW, Pull requests RW, Workflows RW, Metadata R.
# Rotate every 90 days. Put the REAL value in .env (gitignored), never here.
BOT_GH_TOKEN=github_pat_change-me