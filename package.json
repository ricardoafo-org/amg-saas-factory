{
  "name": "amg-factory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -r dotenv/config scripts/schemas-sync.js && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pb:setup": "bash scripts/setup-pocketbase.sh",
    "pb:serve": "node -e \"require('child_process').spawn(process.platform==='win32'?'pocketbase.exe':'./pocketbase',['serve'],{stdio:'inherit',shell:true})\"",
    "migrations:apply": "node -r dotenv/config scripts/migrations-apply.js",
    "schemas:sync": "node -r dotenv/config scripts/schemas-sync.js",
    "flows:validate": "node scripts/validate-flow.js",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "next": "^15.3.1",
    "next-themes": "^0.4.6",
    "pocketbase": "^0.25.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^6.12.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.25.20"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "dotenv": "^16.5.0",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
